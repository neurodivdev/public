---
import { Image } from 'astro:assets';

export interface Props {
  title: string;
  desc: string;
  imgSrc: any;
  imgAlt: string;
  tcText: string;
  tcLink: string;
  appLink?: string;
}

const { 
  title, 
  desc, 
  imgSrc, 
  imgAlt, 
  tcText, 
  tcLink, 
  appLink = "https://play.google.com/store/apps/details?id=dev.neurodiv.asmrcolor" 
} = Astro.props;
---
<div class="reward-section">
  <a href={appLink} target="_blank" rel="noopener noreferrer">
    <Image src={imgSrc} alt={imgAlt} class="reward-img" />
  </a>
  <div class="reward-content">
    <h2>{title}</h2>
    <p set:html={desc}></p>
    <a href={tcLink} target="_blank" class="tc-link">{tcText}</a>
  </div>
</div>

<style>
  .reward-section {
    background-color: var(--card-bg);
    border: 3px solid var(--accent-secondary);
    border-radius: 12px;
    padding: 25px;
    margin: 40px 0 20px 0;
    display: flex;
    align-items: center;
    gap: 25px;
    text-align: left;
    box-shadow: 0 10px 25px rgba(3, 218, 198, 0.15);
    transition: background-color 0.3s ease;
  }
  .reward-img {
    width: 130px;
    height: auto;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .reward-content h2 {
    margin: 0 0 10px 0;
    color: var(--accent-primary);
    font-size: 1.5em;
  }
  .reward-content p {
    margin: 0 0 10px 0;
    font-size: 1.05em;
  }
  .tc-link {
    font-size: 0.8em;
    color: var(--text-muted);
    text-decoration: underline;
  }
  @media (max-width: 600px) {
    .reward-section {
      flex-direction: column;
      text-align: center;
    }
  }
</style>