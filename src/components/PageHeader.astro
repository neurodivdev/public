---
export interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---
<header>
  <h1>{title}</h1>
  <p class="subtitle">{subtitle}</p>
</header>

<style>
  header h1 {
    font-family: 'Luckiest Guy', cursive;
    font-size: 3.5em;
    color: var(--title-text);
    margin-bottom: 10px;
    margin-top: 0;
    font-weight: normal;
    letter-spacing: 2px;
    text-align: center;
    -webkit-text-stroke: 8px var(--title-outline);
    paint-order: stroke fill;
    filter: drop-shadow(0px 4px 0px rgba(0,0,0,0.15));
  }
  header p.subtitle {
    font-size: 1.2em;
    color: var(--text-muted);
    margin-bottom: 40px;
    text-align: center;
  }
</style>