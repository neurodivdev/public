---
export interface Props {
  text: string;
}

const { text } = Astro.props;
---
<div class="value-badge">{text}</div>

<style>
  .value-badge {
    background-color: var(--bg-color);
    border: 2px solid var(--accent-secondary);
    color: var(--text-color);
    padding: 8px 18px;
    border-radius: 50px;
    font-weight: bold;
    font-size: 0.95em;
  }
</style>