---
import { useTranslations, getLangFromUrl } from '../i18n/utils';

export interface Props {
  title: string;
  description: string;
  playStoreLink?: string;
  appStoreLink?: string;
}

const { title, description, playStoreLink, appStoreLink } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang as any);

const hasPlayStore = !!playStoreLink;
const hasAppStore = !!appStoreLink;

const badges = import.meta.glob<{ default: ImageMetadata }>('../assets/store-badges/*.svg', { eager: true });

const getBadge = (store: string) => {
  const localizedPath = `../assets/store-badges/${store}_${lang}.svg`;
  const defaultPath = `../assets/store-badges/${store}_en.svg`;
  return badges[localizedPath]?.default || badges[defaultPath]?.default;
};

const playStoreBadge = getBadge('play_store');
const appStoreBadge = getBadge('app_store');
---
<div class="cta-section">
  <h2>{title}</h2>
  <p>{description}</p>
  <div class="cta-buttons">
    {hasPlayStore && (
      <a href={playStoreLink} target="_blank" rel="noopener noreferrer" class="cta-badge-link">
        <img src={playStoreBadge.src} alt={t('badge.playStoreAlt')} class="cta-badge" />
      </a>
    )}
    {hasAppStore && (
      <a href={appStoreLink} target="_blank" rel="noopener noreferrer" class="cta-badge-link">
        <img src={appStoreBadge.src} alt={t('badge.appStoreAlt')} class="cta-badge" />
      </a>
    )}
  </div>
</div>

<style>
  .cta-section {
    text-align: center;
    margin-top: 50px;
  }
  .cta-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 20px;
  }
  .cta-badge-link {
    display: inline-block;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .cta-badge-link:hover {
    transform: scale(1.05);
  }
  .cta-badge-link:active {
    transform: scale(0.98);
  }
  .cta-badge {
    height: 54px;
    width: auto;
    display: block;
  }
  h2 {
    color: var(--text-color);
  }
</style>
