---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Dynamischer Link zum Übersetzen der aktuellen URL in die andere Sprache.
const targetLang = lang === 'de' ? 'en' : 'de';

const pathname = new URL(Astro.url).pathname;

// Der Regex ersetzt genau den /lang/ oder /lang am Ende Teil sicher.
let targetPath = pathname.replace(new RegExp(`^\\/${lang}(\\/|$)`), `/${targetLang}$1`);

if (targetPath === pathname) {
  // Falls die URL unerwarteterweise kein Sprachpräfix hat, hängen wir es an
  targetPath = `/${targetLang}${pathname}`;
}
---
<a href={targetPath} id="lang-btn" class="control-btn" aria-label="Sprache wechseln" style="text-decoration: none;" onclick="event.preventDefault(); window.location.replace(this.href);">
  {t('langBtnText')}
</a>

<style>
  .control-btn {
    background-color: var(--card-bg);
    color: var(--text-color);
    border: 2px solid var(--accent-primary);
    border-radius: 50px;
    padding: 8px 16px;
    cursor: pointer;
    font-size: 1em;
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
  }
  .control-btn:hover {
    transform: scale(1.05);
    border-color: var(--accent-secondary);
  }
</style>
