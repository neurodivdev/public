---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageDocument from '../../../components/PageDocument.astro';
import FeatureSection from '../../../components/FeatureSection.astro';
import HeroBanner from '../../../components/HeroBanner.astro';
import {getLangFromUrl, getStaticPathsFromUi, useTranslations} from '../../../i18n/utils';
import headerImg from '../../../assets/yurua/header.png';
import BetaCTA from '../../../components/BetaCTA.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export function getStaticPaths() {
  return getStaticPathsFromUi();
}

const backUrl = `/${lang}/`;
---

<BaseLayout
    title={t('yurua.pageTitle')}
    description={t('yurua.pageDesc')}
    backUrl={backUrl}
>
  <HeroBanner imgSrc={headerImg} imgAlt={t('yurua.heroImgAlt')} />

  <PageDocument title={t('yurua.title')}>
    <p set:html={t('yurua.intro')} />
  </PageDocument>

  <FeatureSection title={t('yurua.h2_1')} intro={t('yurua.p_1')}>
    <ul class="custom-list">
      <li set:html={t('yurua.li_1_1')} />
      <li set:html={t('yurua.li_1_2')} />
      <li set:html={t('yurua.li_1_3')} />
    </ul>
  </FeatureSection>

  <FeatureSection title={t('yurua.h2_2')}>
    <ul class="custom-list">
      <li set:html={t('yurua.li_2_1')} />
      <li set:html={t('yurua.li_2_2')} />
      <li set:html={t('yurua.li_2_3')} />
    </ul>
  </FeatureSection>

  <FeatureSection title={t('yurua.h2_3')}>
    <p set:html={t('yurua.p_3')} />
  </FeatureSection>

  <BetaCTA
      appName="yurua"
      googleGroupUrl="https://groups.google.com/g/yurua-testers"
      playStoreUrl="https://play.google.com/store/apps/details?id=dev.neurodiv.yurua"
  />
</BaseLayout>
