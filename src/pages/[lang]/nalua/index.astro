---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageDocument from '../../../components/PageDocument.astro';
import FeatureSection from '../../../components/FeatureSection.astro';
import HeroBanner from '../../../components/HeroBanner.astro';
import {getLangFromUrl, getStaticPathsFromUi, useTranslations} from '../../../i18n/utils';
import headerImg from '../../../assets/nalua/header.webp';
import CtaSection from "../../../components/CtaSection.astro";
import FaqSection from "../../../components/FaqSection.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export function getStaticPaths() {
  return getStaticPathsFromUi();
}

const backUrl = `/${lang}/`;
---

<BaseLayout
    title={t('nalua.pageTitle')}
    description={t('nalua.pageDesc')}
    backUrl={backUrl}
>
  <HeroBanner imgSrc={headerImg} imgAlt={t('nalua.heroImgAlt')} />

  <PageDocument title={t('nalua.title')}>
    <p set:html={t('nalua.intro')} />
  </PageDocument>

  <FeatureSection title={t('nalua.h2_1')} intro={t('nalua.p_1')}>
    <ul class="custom-list">
      <li set:html={t('nalua.li_1_1')} />
      <li set:html={t('nalua.li_1_2')} />
      <li set:html={t('nalua.li_1_3')} />
    </ul>
  </FeatureSection>

  <FeatureSection title={t('nalua.h2_2')}>
    <ul class="custom-list">
      <li set:html={t('nalua.li_2_1')} />
      <li set:html={t('nalua.li_2_2')} />
      <li set:html={t('nalua.li_2_3')} />
    </ul>
  </FeatureSection>

  <FeatureSection title={t('nalua.h2_3')}>
    <p set:html={t('nalua.p_3')} />
  </FeatureSection>

  <CtaSection
      title={t('nalua.ctaTitle')}
      description={t('nalua.ctaDesc')}
      btnText={t('nalua.ctaBtn')}
      btnLink="https://play.google.com/store/apps/details?id=dev.neurodiv.nalua"
  />

  <FaqSection 
      title={t('nalua.faq_title')} 
      prefix="nalua.faq_" 
  />

  <div slot="footer-extra" class="footer-badge-wrapper">
    <a href={t('nalua.only_eu.badge.url')} target="_blank" rel="noopener noreferrer" class="badge-link" aria-label={t('nalua.only_eu.badge.alt')}>
      <span class="badge-mask"></span>
    </a>
  </div>
  </BaseLayout>

  <style>
  .footer-badge-wrapper .badge-link {
    display: inline-block;
  }
  .footer-badge-wrapper .badge-mask {
    display: block;
    width: 220px;
    height: 56px;
    background-color: var(--text-muted);
    -webkit-mask-image: url('https://only-eu.eu/badge/badge_monochrom.svg');
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-image: url('https://only-eu.eu/badge/badge_monochrom.svg');
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    transition: background-color 0.2s ease;
  }
  .footer-badge-wrapper .badge-link:hover .badge-mask {
    background-color: var(--accent-primary);
  }
  </style>
