---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageDocument from '../../../components/PageDocument.astro';
import FeatureSection from '../../../components/FeatureSection.astro';
import HeroBanner from '../../../components/HeroBanner.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import headerImg from '../../../assets/nalua/header.jpg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Dynamische Back-URL basierend auf der aktuellen Sprache
const backUrl = `/${lang}/`;
---

<BaseLayout
    title={t('nalua.pageTitle')}
    description={t('nalua.pageDesc')}
    backUrl={backUrl}
>
  <HeroBanner imgSrc={headerImg} imgAlt={t('nalua.heroImgAlt')} />

  <PageDocument title={t('nalua.title')}>
    <p set:html={t('nalua.intro')} />
  </PageDocument>

  <FeatureSection title={t('nalua.h2_1')} intro={t('nalua.p_1')}>
    <ul class="custom-list">
      <li set:html={t('nalua.li_1_1')} />
      <li set:html={t('nalua.li_1_2')} />
      <li set:html={t('nalua.li_1_3')} />
    </ul>
  </FeatureSection>

  <FeatureSection title={t('nalua.h2_2')}>
    <ul class="custom-list">
      <li set:html={t('nalua.li_2_1')} />
      <li set:html={t('nalua.li_2_2')} />
      <li set:html={t('nalua.li_2_3')} />
    </ul>
  </FeatureSection>

  <FeatureSection title={t('nalua.h2_3')}>
    <p set:html={t('nalua.p_3')} />
  </FeatureSection>
</BaseLayout>
