---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageDocument from '../../../components/PageDocument.astro';
import FeatureSection from '../../../components/FeatureSection.astro';
import FeatureItem from '../../../components/FeatureItem.astro';
import CtaSection from '../../../components/CtaSection.astro';
import HeroBanner from '../../../components/HeroBanner.astro';
import FeaturesGrid from '../../../components/FeaturesGrid.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import headerImg from '../../../assets/asmr-color-reveal-kids/header-en.webp';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout 
  title={t('asmr.pageTitle')} 
  description={t('asmr.pageDesc')}
  backUrl={`/${lang}/`}
>
  <HeroBanner imgSrc={headerImg} imgAlt={t('asmr.heroImgAlt')} />

  <PageDocument title={`<span class="asmr-title">${t('asmr.title')}</span>`}>
    <p class="asmr-subtitle">
      {t('asmr.subtitle')}
    </p>
  </PageDocument>

  <FeatureSection title={t('asmr.mechTitle')} intro={t('asmr.mechIntro')}>
    <FeaturesGrid>
      <FeatureItem title={t('asmr.mech1Title')} description={t('asmr.mech1Desc')} />
      <FeatureItem title={t('asmr.mech2Title')} description={t('asmr.mech2Desc')} />
      <FeatureItem title={t('asmr.mech3Title')} description={t('asmr.mech3Desc')} />
    </FeaturesGrid>
  </FeatureSection>

  <FeatureSection title={t('asmr.safeTitle')} intro={t('asmr.safeIntro')}>
    <ul class="custom-list">
      <li set:html={t('asmr.safe1')} />
      <li set:html={t('asmr.safe2')} />
      <li set:html={t('asmr.safe3')} />
      <li set:html={t('asmr.safe4')} />
      <li set:html={t('asmr.safe5')} />
    </ul>
  </FeatureSection>

  <CtaSection 
    title={t('asmr.ctaTitle')} 
    description={t('asmr.ctaDesc')} 
    btnText={t('asmr.ctaBtn')} 
    btnLink="https://play.google.com/store/apps/details?id=dev.neurodiv.asmrcolor" 
  />
</BaseLayout>
<style>
  /* Holt den poppigen ASMR-Font in die weiße Karte zurück */
  :global(.asmr-title) {
    font-family: 'Luckiest Guy', system-ui, sans-serif;
    color: var(--title-text);
    -webkit-text-stroke: 1.5px var(--title-outline);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Korrigiert die Farbe des Untertitels (Dunkelgrau/Hellgrau je nach Theme statt Blau) */
  .asmr-subtitle {
    font-size: 1.15em;
    font-weight: 500;
    color: var(--text-color);
    margin-top: -10px;
    opacity: 0.85;
  }
</style>
