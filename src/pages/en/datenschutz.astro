---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageDocument from '../../components/PageDocument.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const name = "Dennis Hartrampf";
const email = "info@neurodiv.dev";
---

<BaseLayout title={t('privacy.title')} backUrl="javascript:history.back()">
  <PageDocument title={t('privacy.title')}>
    <p class="text-muted">{t('privacy.lastUpdated')}</p>

    <p>{t('privacy.intro')}</p>

    <h2>{t('privacy.h1')}</h2>
    <p>{t('privacy.p1')}</p>
    <ul class="custom-list">
        <li set:html={t('privacy.li1_1')} />
        <li set:html={t('privacy.li1_2')} />
        <li set:html={t('privacy.li1_3')} />
    </ul>

    <h2>{t('privacy.h2')}</h2>
    <p set:html={t('privacy.p2')} />

    <h2>{t('privacy.h3')}</h2>
    <p>{t('privacy.p3')}</p>
    <ul class="custom-list">
        <li set:html={t('privacy.li3_1')} />
        <li set:html={t('privacy.li3_2')} />
    </ul>
    <p>{t('privacy.p3_2')}</p>

    <h2>{t('privacy.h4')}</h2>
    <p>{t('privacy.p4')}</p>

    <h2>{t('privacy.h5')}</h2>
    <p>{t('privacy.p5')}</p>
    <ul class="custom-list">
        <li>{t('privacy.li5_1')}</li>
        <li>{t('privacy.li5_2')}</li>
        <li>{t('privacy.li5_3')}</li>
    </ul>

    <h2>{t('privacy.h6')}</h2>
    <p>{t('privacy.p6')}</p>

    <h2 style="margin-top: 30px;">{t('privacy.h7')}</h2>
    <p>{t('privacy.p7')}</p>
    <p><a href="mailto:android-support@neurodiv.dev">android-support@neurodiv.dev</a></p>
  </PageDocument>
</BaseLayout>